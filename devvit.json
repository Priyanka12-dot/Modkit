        "endpoint": "/internal/menu/analyze-comment"
      },
      {
        "label": "📊 ModKit: Recent Alerts",
        "description": "Show recent toxicity alerts for this subreddit",
        "forUserType": "moderator",
        "location": ["subreddit"],
        "endpoint": "/internal/menu/show-alerts"
      }
    ]
  },

  "permissions": {
    "reddit": { "enable": true, "scope": "moderator" }
  }
}
